ANN_MODEL_PROVIDER=anthropic
ANN_MODEL=claude-sonnet-5
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional. Directory for generated headlines-*.md / retrospective-*.md files.
# Defaults to the repo root. The container sets this to /data.
# ANN_DIGEST_DIR=

# Optional. Comma-separated extras: GUARDIAN, BBC, NPR.
# ANN_EXTRA_OUTLETS=

# Optional. Set to 0 to disable Google News -> publisher URL resolution.
# ANN_RESOLVE_URLS=1
